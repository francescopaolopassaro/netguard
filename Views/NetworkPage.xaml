<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NetGuard.ViewModels"
             xmlns:models="clr-namespace:NetGuard.Models"
             x:Class="NetGuard.Views.NetworkPage"
             Title="Network Monitor">

    <ContentPage.Resources>
        <Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="Padding"        Value="0,7"/>
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#4A5568, Dark=#A0AEC0}"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Padding="20,14,20,8" Spacing="10">
            <Label Text="Network Connections" FontSize="22" FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1A202C, Dark=#F7FAFC}"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#3182CE" WidthRequest="20" HeightRequest="20"
                               VerticalOptions="Center"/>
            <Label Text="{Binding StatusMessage}" VerticalOptions="Center" FontSize="12"
                   TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}"/>
            <Button Text="⟳  Refresh" Command="{Binding RefreshCommand}"
                    BackgroundColor="#3182CE" TextColor="White"
                    CornerRadius="8" Padding="12,7"
                    HorizontalOptions="EndAndExpand"/>
            <Button Text="⬇  Export CSV"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light=#CBD5E0, Dark=#4A5568}"
                    TextColor="{AppThemeBinding Light=#4A5568, Dark=#A0AEC0}"
                    BorderWidth="1" CornerRadius="8" Padding="12,7"
                    Clicked="OnExportClicked"/>
        </HorizontalStackLayout>

        <!-- Filters -->
        <Grid Grid.Row="1" Padding="20,0,20,10"
              ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light=#CBD5E0, Dark=#4A5568}"
                    Padding="10,6">
                <SearchBar Placeholder="Filter by IP, domain or process…"
                           Text="{Binding FilterText}"
                           BackgroundColor="Transparent"/>
            </Border>
            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                <CheckBox IsChecked="{Binding ShowAllStates}"/>
                <Label Text="All states" VerticalOptions="Center" FontSize="13"
                       TextColor="{AppThemeBinding Light=#4A5568, Dark=#A0AEC0}"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2"
                   Text="{Binding Connections.Count, StringFormat='{0} connections'}"
                   VerticalOptions="Center" FontSize="13"
                   TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}"/>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="2" Padding="20,0" ColumnDefinitions="76,*,100,110,100,90"
              BackgroundColor="{AppThemeBinding Light=#EDF2F7, Dark=#2D3748}">
            <Label Grid.Column="0" Text="Proto"       Style="{StaticResource ColHeader}"/>
            <Label Grid.Column="1" Text="Destination" Style="{StaticResource ColHeader}"/>
            <Label Grid.Column="2" Text="Port"        Style="{StaticResource ColHeader}"/>
            <Label Grid.Column="3" Text="State"       Style="{StaticResource ColHeader}"/>
            <Label Grid.Column="4" Text="Process"     Style="{StaticResource ColHeader}"/>
            <Label Grid.Column="5" Text="Threat"      Style="{StaticResource ColHeader}"/>
        </Grid>

        <!-- Connection list — tap a row to open ConnectionDetailPage -->
        <CollectionView Grid.Row="3"
                        x:Name="ConnectionList"
                        ItemsSource="{Binding Connections}"
                        SelectionMode="Single"
                        SelectionChanged="OnConnectionSelected"
                        EmptyView="No connections — press Refresh">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NetworkConnection">
                    <Grid ColumnDefinitions="76,*,100,110,100,90"
                          Padding="20,0" MinimumHeightRequest="46">

                        <!-- Row bg — threat-tinted -->
                        <BoxView Grid.ColumnSpan="6" VerticalOptions="Fill">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView"
                                             Binding="{Binding Threat}" Value="High">
                                    <Setter Property="Color" Value="#FFF5F5"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView"
                                             Binding="{Binding Threat}" Value="Medium">
                                    <Setter Property="Color" Value="#FFFDF5"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView"
                                             Binding="{Binding Threat}" Value="Clean">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <!-- Protocol pill -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 4"
                                BackgroundColor="{AppThemeBinding Light=#EBF8FF, Dark=#2A4365}"
                                Stroke="Transparent" HorizontalOptions="Start"
                                VerticalOptions="Center" Padding="6,2">
                            <Label Text="{Binding Protocol}" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#2B6CB0, Dark=#63B3ED}"/>
                        </Border>

                        <!-- Domain + IP -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center"
                                             Padding="0,5">
                            <Label Text="{Binding Domain}" FontSize="13" FontAttributes="Bold"
                                   IsVisible="{Binding Domain,
                                       Converter={StaticResource IsNotEmptyConverter}}"
                                   TextColor="{AppThemeBinding Light=#2D3748, Dark=#E2E8F0}"
                                   LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding RemoteAddress}" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#A0AEC0, Dark=#718096}"/>
                        </VerticalStackLayout>

                        <!-- Port -->
                        <Label Grid.Column="2" Text="{Binding RemotePort}"
                               VerticalOptions="Center" FontSize="13"
                               TextColor="{AppThemeBinding Light=#4A5568, Dark=#CBD5E0}"/>

                        <!-- State -->
                        <Label Grid.Column="3" Text="{Binding State}"
                               VerticalOptions="Center" FontSize="12"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}"/>

                        <!-- Process -->
                        <Label Grid.Column="4" Text="{Binding ProcessName}"
                               VerticalOptions="Center" FontSize="12"
                               TextColor="{AppThemeBinding Light=#4A5568, Dark=#CBD5E0}"
                               LineBreakMode="TailTruncation"/>

                        <!-- Threat badge -->
                        <Border Grid.Column="5" StrokeShape="RoundRectangle 4"
                                Stroke="Transparent" Padding="6,2"
                                VerticalOptions="Center" HorizontalOptions="Start">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Threat}" Value="High">
                                    <Setter Property="BackgroundColor" Value="#FED7D7"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Threat}" Value="Medium">
                                    <Setter Property="BackgroundColor" Value="#FEEBC8"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Threat}" Value="Clean">
                                    <Setter Property="BackgroundColor" Value="#C6F6D5"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Threat}" Value="Unknown">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light=#EDF2F7, Dark=#2D3748}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding Threat}" FontSize="11">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Threat}" Value="High">
                                        <Setter Property="TextColor" Value="#C53030"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Threat}" Value="Medium">
                                        <Setter Property="TextColor" Value="#C05621"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Threat}" Value="Clean">
                                        <Setter Property="TextColor" Value="#276749"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Threat}" Value="Unknown">
                                        <Setter Property="TextColor" Value="#718096"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <!-- Row separator -->
                        <BoxView Grid.ColumnSpan="6" HeightRequest="1" VerticalOptions="End"
                                 Color="{AppThemeBinding Light=#EDF2F7, Dark=#2D3748}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>

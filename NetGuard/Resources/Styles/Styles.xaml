<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Stile base per tutte le pagine -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundDark}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <!-- Card moderna (Border + StrokeShape) - versione stabile per .NET 9 -->
    <Style x:Key="ModernCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardDark}" />
        <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
        <!-- Corner radius tramite stringa (funziona meglio in Style) -->
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
    </Style>

    <!-- Header grande -->
    <Style x:Key="StatusHeader" TargetType="Label">
        <Setter Property="FontSize" Value="38" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- Numeri grandi -->
    <Style x:Key="BigNumber" TargetType="Label">
        <Setter Property="FontSize" Value="54" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- Icone Font Awesome -->
    <Style x:Key="FaIcon" TargetType="Label">
        <Setter Property="FontFamily" Value="FaSolid" />
        <Setter Property="FontSize" Value="34" />
    </Style>

    <!-- Badge per minacce -->
    <Style x:Key="ThreatBadge" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <!-- RIMOSSO CornerRadius: non è una proprietà valida per Label -->
        <Setter Property="TextColor" Value="White" />
    </Style>
    <!-- Pulsanti Quick Actions moderni -->
    <Style x:Key="QuickActionButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#1E2937" />
        <Setter Property="TextColor" Value="#E0E7FF" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#3B82F6" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>
</ResourceDictionary>
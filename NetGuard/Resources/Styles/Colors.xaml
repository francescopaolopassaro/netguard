<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="BackgroundDark">#0A0F1C</Color>
    <Color x:Key="SurfaceDark">#121A2E</Color>
    <Color x:Key="CardDark">#1A2339</Color>
    <Color x:Key="CardBorder">#2A3552</Color>
    <Color x:Key="GlassOverlay">#FFFFFF0A</Color>

    <Color x:Key="TextPrimary">#E0E7FF</Color>
    <Color x:Key="TextSecondary">#94A3C0</Color>
    <Color x:Key="TextMuted">#64748B</Color>

    <Color x:Key="PrimaryAccent">#3B82F6</Color>
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>

    <Color x:Key="ThreatCritical">#FF0040</Color>

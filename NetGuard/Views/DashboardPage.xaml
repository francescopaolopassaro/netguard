<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:NetGuard.Converters"
             x:Class="NetGuard.Views.DashboardPage"
             Title="Dashboard">

    <ContentPage.Resources>
        <converters:ThreatColorConverter x:Key="ThreatColor" />
    </ContentPage.Resources>

    <ScrollView VerticalScrollBarVisibility="Always">
        <VerticalStackLayout Spacing="24">

            <!-- Main Header with Logo and Status -->
            <Border Style="{StaticResource ModernCard}">
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="24">
                    <!-- Logo -->
                    <Label Grid.Column="0"
                           Text="&#xf0ac;" 
                           FontFamily="FaSolid"
                           FontSize="46"
                           TextColor="#3B82F6"
                           VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1" Margin="20,0,0,0" Spacing="6">
                        <Label Text="NETGUARD" 
                               FontSize="34" 
                               FontAttributes="Bold" 
                               TextColor="#60A5FA" />

                        <!-- Status with icon and color -->
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="{Binding OverallStatusIcon}" 
                                   FontSize="28"
                                   FontFamily="FaSolid"
                                   TextColor="{Binding OverallStatusColor}" />
                            <Label Text="{Binding OverallStatus}" 
                                   Style="{StaticResource StatusHeader}" 
                                   FontSize="26"
                                   TextColor="{Binding OverallStatusColor}" />
                        </HorizontalStackLayout>

                        <Label Text="Real-time network &amp; process protection" 
                               TextColor="{StaticResource TextSecondary}" 
                               FontSize="15" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                           Text="&#xf013;" 
                           FontFamily="FaSolid"
                           FontSize="28"
                           TextColor="{StaticResource TextMuted}"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Progress Bar (visible during scan/refresh) -->
            <ProgressBar IsVisible="{Binding IsBusy}" 
                         Progress="{Binding Progress, Mode=OneWay}" 
                         HeightRequest="6" 
                         Margin="10,0" />

            <!-- Metrics Cards -->
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" 
              ColumnSpacing="16" RowSpacing="16">

                <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                    <VerticalStackLayout Spacing="12" Padding="20" x:Name="ConnCard">
                        <Label Text="&#xf0ac;" FontFamily="FaSolid" FontSize="42" TextColor="#60A5FA" HorizontalOptions="Center" />
                        <Label Text="{Binding ActiveConnections}" Style="{StaticResource BigNumber}" HorizontalOptions="Center" />
                        <Label Text="Active Connections" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ModernCard}">
                    <VerticalStackLayout Spacing="12" Padding="16" 
                                         x:Name="ProcCard">
                        <Label Text="&#xf085;" Style="{StaticResource FaIcon}" TextColor="#A78BFA" />
                        <Label Text="{Binding ActiveProcesses}" Style="{StaticResource BigNumber}" />
                        <Label Text="Processes" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                    <VerticalStackLayout Spacing="12" Padding="16" 
                                         x:Name="ThreatCard">
                        <Label Text="&#xf06a;" Style="{StaticResource FaIcon}" 
                               TextColor="{Binding ThreatCount, Converter={StaticResource ThreatColor}}" />
                        <Label Text="{Binding ThreatCount}" Style="{StaticResource BigNumber}" />
                        <Label Text="Threats Detected" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ModernCard}">
                    <VerticalStackLayout Spacing="12" Padding="16" 
                                         x:Name="AlertCard">
                        <Label Text="&#xf0f3;" Style="{StaticResource FaIcon}" TextColor="#F87171" />
                        <Label Text="{Binding UnreadAlerts}" Style="{StaticResource BigNumber}" />
                        <Label Text="Unread Alerts" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <Border Style="{StaticResource ModernCard}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Quick Actions" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Full Scan"
        Command="{Binding RefreshCommand}"
        FontAttributes="Bold"
        BackgroundColor="#3B82F6"
        TextColor="White"
        CornerRadius="12"
        Padding="24,16"
        HeightRequest="54">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="FaSolid" 
                                                 Glyph="&#xf04b;" 
                                                 Color="White" 
                                                 Size="20" />
                                                    </Button.ImageSource>
                                                </Button>

                                                <Button Text="Pause Protection"
                                BackgroundColor="#1E2937"
                                TextColor="#E0E7FF"
                                CornerRadius="12"
                                Padding="24,16"
                                HeightRequest="54">
                                                    <Button.ImageSource>
                                                        <FontImageSource FontFamily="FaSolid" 
                                                 Glyph="&#xf023;" 
                                                 Color="#E0E7FF" 
                                                 Size="20" />
                                                    </Button.ImageSource>
                                                </Button>

                                                <Button Text="Export Report"
                                Clicked="OnExportAlertsClicked"
                                BackgroundColor="#1E2937"
                                TextColor="#E0E7FF"
                                CornerRadius="12"
                                Padding="24,16"
                                HeightRequest="54">
                                                    <Button.ImageSource>
                                                        <FontImageSource FontFamily="FaSolid" 
                                                 Glyph="&#xf0c7;" 
                                                 Color="#E0E7FF" 
                                                 Size="20" />
                                                    </Button.ImageSource>
                                                </Button>
                                            </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Recent Alerts -->
            <Border Style="{StaticResource ModernCard}">
                <VerticalStackLayout Spacing="18">
                    <Label Text="Recent Alerts" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                    <CollectionView x:Name="AlertsCollectionView"
                                    ItemsSource="{Binding RecentAlerts}" 
                                    HeightRequest="380" 
                                    SelectionMode="Single"
                                    SelectionChanged="OnAlertSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModernCard}" Padding="18" Margin="0,6">
                                    <HorizontalStackLayout Spacing="18">
                                        <Label Text="{Binding Icon}" FontSize="32" VerticalOptions="Center" />
                                        <VerticalStackLayout Spacing="6" VerticalOptions="CenterAndExpand">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding TimeAgo}" TextColor="{StaticResource TextMuted}" FontSize="13" />
                                        </VerticalStackLayout>
                                        <Label Text="{Binding Severity}" 
                                               Style="{StaticResource ThreatBadge}"
                                               BackgroundColor="{Binding Severity, Converter={StaticResource ThreatColor}}" 
                                               HorizontalOptions="End" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>